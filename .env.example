# --- Docker / Dokploy ---
# Host port for direct IP:port access (e.g. http://1.2.3.4:8080). Set when host
# port 80 is already taken (Traefik/Dokploy uses it).
WEBAPP_HOST_PORT=8080
# Port nginx listens on inside the container. Traefik/Dokploy domains must use
# THIS port — not WEBAPP_HOST_PORT.
WEBAPP_CONTAINER_PORT=80
#
# Dokploy domain setup (Domains tab):
#   service name: webapp
#   port:         80   (= WEBAPP_CONTAINER_PORT)
# Then redeploy after adding/changing the domain.

# --- API ---
# Base URL of the São Miguel Bus v3 API.
# Production cutover to api.saomiguelbus.com is pending; v3 currently lives on staging.
VITE_API_URL=https://staging.api.saomiguelbus.com
# Active island tenant key (sent as the X-Island header on every request).
VITE_ISLAND_KEY=sao-miguel

# --- SEO / hosting ---
# Canonical public base URL of this app (used for canonical links + sitemap).
VITE_SITE_URL=https://app.saomiguelhub.com
# Root domain used to build module subdomains (radares.<base>, meteorologia.<base>, ...).
VITE_BASE_DOMAIN=saomiguelhub.com

# --- Native apps (install promotion) ---
# Build-time only (must redeploy/rebuild after changing). Leave empty to show
# "Coming soon" and link buttons to https://<VITE_BASE_DOMAIN>.
VITE_ANDROID_APP_URL=
VITE_IOS_APP_URL=https://apps.apple.com/app/id6777066837
# Numeric iOS app id for the native Smart App Banner.
VITE_IOS_APP_ID=6777066837
