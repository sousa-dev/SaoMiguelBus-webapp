# --- API ---
# Base URL of the São Miguel Bus v3 API.
# Production cutover to api.saomiguelbus.com is pending; v3 currently lives on staging.
VITE_API_URL=https://staging.api.saomiguelbus.com
# Active island tenant key (sent as the X-Island header on every request).
VITE_ISLAND_KEY=sao-miguel

# --- SEO / hosting ---
# Canonical public base URL of this app (used for canonical links + sitemap).
VITE_SITE_URL=https://app.saomiguelbus.com
# Root domain used to build module subdomains (radares.<base>, meteorologia.<base>, ...).
VITE_BASE_DOMAIN=saomiguelbus.com

# --- Native apps (install promotion) ---
# Store URLs are not published yet — set them here once available and the
# install banner / sidebar buttons update automatically. Leave empty to show a
# "coming soon" state.
VITE_ANDROID_APP_URL=
VITE_IOS_APP_URL=
# Optional numeric iOS app id for the native Smart App Banner.
VITE_IOS_APP_ID=
